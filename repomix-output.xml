    pub act_vert: &'static str,
    pub demons: &'static str,
    pub level: &'static str,
    pub loaded: &'static str,
    pub waiting: &'static str,
    pub reward: &'static str,
    pub time_left: &'static str,
    pub success: &'static str,
    pub fail: &'static str,
}

